# ─── Database ───
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/digitalca
DATABASE_URL_SYNC=postgresql+psycopg://postgres:postgres@localhost:5432/digitalca

# ─── Redis ───
REDIS_URL=redis://localhost:6379/0

# ─── AWS ───
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=digitalca-documents
TEXTRACT_REGION=ap-south-1
BEDROCK_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0

# ─── Cognito ───
COGNITO_USER_POOL_ID=
COGNITO_APP_CLIENT_ID=
# Must match your Cognito user pool region (e.g. us-east-1 for us-east-1_xxxxx pools)
COGNITO_REGION=ap-south-1

# ─── App ───
APP_ENV=development
CORS_ORIGINS=http://localhost:3000
SECRET_KEY=change-me-in-production
