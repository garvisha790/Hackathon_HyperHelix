# ============================================
# Production Environment Configuration
# ============================================

# Application
APP_ENV=production
DEBUG=False

# Database (AWS RDS)
DATABASE_URL=postgresql+asyncpg://username:password@rds-endpoint.region.rds.amazonaws.com:5432/taxodo

# Redis (AWS ElastiCache)
REDIS_URL=redis://elasticache-endpoint.region.cache.amazonaws.com:6379/0

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# S3 Bucket
S3_BUCKET_NAME=taxodo-documents-prod

# AWS Cognito
COGNITO_REGION=us-east-1
COGNITO_USER_POOL_ID=us-east-1_xxxxxxxxx
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
COGNITO_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# CORS
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Logging
LOG_LEVEL=INFO

# Frontend
NEXT_PUBLIC_API_URL=https://api.yourdomain.com
BACKEND_URL=http://backend:8000

# Optional: AWS Bedrock & Textract (if not using IAM role)
# AWS_BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0
# AWS_TEXTRACT_ENABLED=true
